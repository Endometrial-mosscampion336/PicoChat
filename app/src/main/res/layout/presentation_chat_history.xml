<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ds_black">

    <com.markusmaribu.picochat.ui.ScaleLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/chatHistoryBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/ds_gray_stripe">

            <LinearLayout
                android:id="@+id/topSidebar"
                android:layout_width="@dimen/ds_tool_strip_width"
                android:layout_height="0dp"
                android:background="@color/ds_white"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <FrameLayout
                    android:id="@+id/signalContainer"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="3dp"
                    android:background="@color/ds_black"
                    android:visibility="invisible">

                    <View
                        android:id="@+id/signalLineTop"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_gravity="top"
                        android:layout_marginHorizontal="4dp"
                        android:layout_marginTop="4dp"
                        android:background="#FF00C800" />

                    <ImageView
                        android:id="@+id/signalIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_signal" />

                    <View
                        android:id="@+id/signalLineBottom"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_gravity="bottom"
                        android:layout_marginHorizontal="4dp"
                        android:layout_marginBottom="4dp"
                        android:background="#FF00C800" />

                </FrameLayout>

                <View
                    android:id="@+id/signalSeparator"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginHorizontal="3dp"
                    android:layout_marginTop="3dp"
                    android:background="@drawable/bg_dotted_separator"
                    android:layerType="software" />

                <com.markusmaribu.picochat.ui.ScrollBarVisualizerView
                    android:id="@+id/scrollBarVisualizer"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:layout_marginVertical="3dp" />

                <View
                    android:id="@+id/roomLetterSeparator"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginHorizontal="3dp"
                    android:layout_marginBottom="3dp"
                    android:background="@drawable/bg_dotted_separator"
                    android:layerType="software" />

                <FrameLayout
                    android:id="@+id/roomLetterContainer"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="3dp"
                    android:background="@color/ds_key_bg"
                    android:visibility="invisible">

                    <TextView
                        android:id="@+id/roomLetter"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:fontFamily="@font/cozette_vector"
                        android:textColor="@color/ds_black"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="A" />

                </FrameLayout>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/chatRecyclerView"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@android:color/transparent"
                android:clipToPadding="false"
                android:paddingHorizontal="6dp"
                android:paddingBottom="2dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/topSidebar"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.markusmaribu.picochat.ui.ScaleLayout>

    <View
        android:id="@+id/presentationOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="@color/ds_gray_stripe"
        android:visibility="gone" />

</FrameLayout>
